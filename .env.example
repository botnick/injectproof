# InjectProof — environment template
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# ── Required ─────────────────────────────────────────────────

# SQLite DB (file-relative path). Change to Postgres URL for prod.
DATABASE_URL="file:./injectproof.db"

# JWT signing key. Must be ≥ 32 bytes — src/lib/auth.ts refuses to boot
# without a strong secret (the legacy hardcoded fallback has been removed).
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET="replace-me-with-at-least-32-bytes-of-real-random-data"

# AES-256 key for encrypting extracted credentials / schema data at rest.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
EVIDENCE_KEY="replace-me-with-a-32-byte-base64-key"

# ── App ──────────────────────────────────────────────────────

NEXT_PUBLIC_APP_NAME="InjectProof"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Scanner ──────────────────────────────────────────────────

SCANNER_USER_AGENT="InjectProof-Scanner/1.0"
# Worker pool size — in-process concurrent scans. Start low; raise only after
# measuring Puppeteer memory footprint on your hardware.
SCANNER_MAX_CONCURRENT=2
SCANNER_REQUEST_TIMEOUT=30000
SCANNER_MAX_CRAWL_DEPTH=10
SCANNER_MAX_URLS=500

# Allow scanning internal / private-range hosts (localhost, 10.x, 192.168.x,
# 172.16.x, 169.254.x). Set this to `true` ONLY when the whole scanner sits
# inside a trusted internal network and you are legitimately testing systems
# you own (e.g. internal staging, employees' apps before prod release).
# For public-facing deploys keep this false — the SSRF guard protects against
# accidental or malicious scans of cloud metadata endpoints + RFC1918 peers.
# Default: false. (อนุญาต scan host ภายในองค์กร — เปิดเมื่อใช้ทดสอบระบบของตัวเองเท่านั้น)
SCANNER_ALLOW_INTERNAL_TARGETS=false

# ── Evidence / artifact storage ──────────────────────────────

# Root directory where the scanner writes request/response/screenshot/DOM
# artifacts per finding. Must be writable by the Next.js process.
EVIDENCE_DIR="./evidence"

# ── Scheduled scans ──────────────────────────────────────────

# When true, the worker boots the cron scheduler and drives ScheduledScan rows.
SCHEDULER_ENABLED=true

# ── Observability (optional) ─────────────────────────────────

# Comma-separated list of webhook URLs that NotificationConfig can route to.
# Leave unset to disable notification delivery.
# NOTIFY_SLACK_WEBHOOK=
# NOTIFY_DISCORD_WEBHOOK=
# NOTIFY_TEAMS_WEBHOOK=
